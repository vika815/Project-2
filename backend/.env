# ==============================
#   Smart Caption Generator - ENV
# ==============================

# Server Port
PORT=5000

# MongoDB Connection URI
# Replace with your MongoDB Atlas URI or keep for local MongoDB
MONGO_URI=mongodb://localhost:27017/smart_caption_db

# JWT Secret (change this to a long, random string in production!)
JWT_SECRET=generate_production_2024

# JWT Expiry
JWT_EXPIRES_IN=7d

# CORS Origin (your frontend / Expo dev URL)
CORS_ORIGIN=*

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Paste your Web Client ID from Google Cloud Console here.
# Go to: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=876358085436-j0cqth3r28sefq9051si1f9rifodjc4c.apps.googleusercontent.com
